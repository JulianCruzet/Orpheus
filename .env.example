# Orpheus environment variables
# Copy to .env and fill in values before running locally.

# LLM provider (Gemini)
GEMINI_API_KEY=

# Shopify Admin API
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=

# Optional providers (enable when corresponding features are built)
OPENAI_API_KEY=
FIRECRAWL_API_KEY=

# Supabase auth (public client keys for browser auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-side aliases (if needed by backend handlers)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# App mode
MOCK_MODE=false
